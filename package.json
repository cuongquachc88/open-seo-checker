{
  "name": "open-seo-checker",
  "version": "0.1.0",
  "description": "Open-source, cross-platform SEO auditing tool with CLI and Web UI",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "open-seo-checker": "dist/index.js"
  },
  "scripts": {
    "build": "pnpm --filter open-seo-checker-frontend build && tsc",
    "build:frontend": "pnpm --filter open-seo-checker-frontend build",
    "build:backend": "tsc",
    "dev": "concurrently -n backend,frontend -c blue,magenta \"pnpm dev:server\" \"pnpm dev:frontend\"",
    "dev:server": "tsx watch src/index.ts serve",
    "dev:frontend": "pnpm --filter open-seo-checker-frontend dev",
    "server": "node dist/index.js serve",
    "start": "node dist/index.js serve",
    "crawl": "node dist/index.js crawl",
    "test": "vitest",
    "lint": "eslint src --ext .ts",
    "postinstall": "node scripts/postinstall.mjs"
  },
  "keywords": [
    "seo",
    "crawler",
    "seo-audit",
    "screaming-frog-alternative",
    "technical-seo",
    "website-crawler"
  ],
  "author": "Open SEO Checker Contributors",
  "license": "MIT",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  },
  "dependencies": {
    "@hono/node-server": "^1.14.0",
    "@hono/node-ws": "^1.1.1",
    "@hono/zod-validator": "^0.4.3",
    "better-sqlite3": "^12.2.0",
    "cheerio": "^1.0.0",
    "commander": "^13.1.0",
    "csv-stringify": "^6.5.2",
    "exceljs": "^4.4.0",
    "hono": "^4.7.5",
    "linkedom": "^0.18.9",
    "open": "^10.1.0",
    "playwright": "^1.52.0",
    "robots-parser": "^3.0.1",
    "undici": "^7.8.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.14.0",
    "@typescript-eslint/eslint-plugin": "^8.29.1",
    "@typescript-eslint/parser": "^8.29.1",
    "concurrently": "^10.0.3",
    "eslint": "^9.24.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1"
  }
}
