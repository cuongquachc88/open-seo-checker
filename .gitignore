# Dependencies
node_modules/
**/node_modules/

# Build output
dist/
**/dist/
*.log
.logs/

# API build output (TypeScript -> dist/)
/packages/api/dist/

# Web build output (Vite) goes to /public at the workspace root
/public/index.html
/public/favicon.svg
/public/assets/
public/styles/tailwind.css

# Vite tsbuildinfo (regenerated each build)
/packages/web/*.tsbuildinfo
/packages/web/vite.config.d.ts
/packages/web/vite.config.js

# Runtime artefacts (kept local, deletable)
.env
.env.local
crawls/
exports/
.DS_Store
coverage/
tokens.json

# Playwright artefacts
/tests/e2e/.results/
/tests/e2e/playwright-report/
/packages/api/test-results/
/packages/web/test-results/
/playwright/.cache/
/playwright/.bin/
